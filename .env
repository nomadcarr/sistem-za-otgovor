# ============================================================
#  CLAUDE AI
# ============================================================
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
#  FACEBOOK
# ============================================================
# Взима се от Meta Developer Console -> App -> Messenger -> Page Access Token
FB_PAGE_ACCESS_TOKEN=EAAG...
# Произволен низ, който сам избираш за верификация на webhook-а
FB_VERIFY_TOKEN=my_secret_verify_token_123
# Взима се от Meta Developer Console -> App Settings -> Basic -> App Secret
FB_APP_SECRET=abc123...
# ID на твоята Facebook страница
FB_PAGE_ID=123456789

# ============================================================
#  TIKTOK
# ============================================================
# TikTok for Business -> My Apps -> Access Token
TIKTOK_ACCESS_TOKEN=...
TIKTOK_APP_ID=...
TIKTOK_APP_SECRET=...
# ID на TikTok бизнес акаунта
TIKTOK_ADVERTISER_ID=...

# ============================================================
#  EMAIL (Gmail препоръчан - трябва App Password, не обичайната парола)
#  Google Account -> Security -> 2-Step Verification -> App Passwords
# ============================================================
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Имейл, на който да се изпращат дневните репорти
REPORT_RECIPIENT_EMAIL=your_email@gmail.com

# Ключова дума за разпознаване на OLX имейли (в Subject или From)
OLX_EMAIL_FILTER=olx.bg

# ============================================================
#  НАСТРОЙКИ НА СИСТЕМАТА
# ============================================================
# След колко минути без отговор да попитаме клиента дали се е отказал
INACTIVITY_TIMEOUT_MINUTES=60
# По кое време да се изпрати дневния репорт (HH:MM)
DAILY_REPORT_TIME=23:30
# Часова зона
TIMEZONE=Europe/Sofia
